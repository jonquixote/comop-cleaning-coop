# Copy to .env and fill. NEVER commit .env (see .gitignore).
# ADR-0004 §4: the app connects as app_user; migrations/seed connect as app_owner.
# Both are NON-superuser, NEVER BYPASSRLS. The bootstrap `postgres` superuser is
# used only to create those roles (platform/db/roles.sql) and for admin.

# --- bootstrap (roles setup / admin only) ---
POSTGRES_SUPER_PASSWORD=change-me-super

# --- role passwords (used by roles.sql via psql -v) ---
OWNER_PASSWORD=change-me-owner
APP_PASSWORD=change-me-app

# --- connection strings the app/migrations use ---
# migrations + seed (Tasks 3,4,7) run as app_owner:
OWNER_DATABASE_URL=postgresql://app_owner:change-me-owner@localhost:5432/comop
# the runtime app connects as app_user (Task 4 pool):
APP_DATABASE_URL=postgresql://app_user:change-me-app@localhost:5432/comop

# --- auth (Task 6) ---
SESSION_SECRET=change-me-32+bytes-random

# --- backups / restore drill (Task 8): off-site, encrypted (impl §3) ---
BACKUP_PASS=                # backup encryption passphrase (aes-256, pbkdf2). REQUIRED.
OFFSITE_REPO=               # off-box target. Local fs path, OR rclone:b2:<bucket>, OR s3://<bucket>
SCRATCH_DB_NAME=comop_scratch
PAGE_CHANNEL=               # on-call channel/name (std §7), e.g. #comop-oncall
# Production primary (deferred under staging allowance) — pgBackRest physical PITR:
PGBACKREST_REPO=           # e.g. s3-compatible Backblaze B2 / Hetzner Storage Box
PGBACKREST_CIPHER_PASS=    # repo encryption passphrase
B2_ACCOUNT_ID=
B2_ACCOUNT_KEY=
B2_BUCKET=
