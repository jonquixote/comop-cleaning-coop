# OS
.DS_Store

# Secrets — never commit (.env.example is committed; .env is not)
.env
.env.*
!.env.example

# Node / build (forward-looking for Task 1+)
node_modules/
.next/
dist/
build/
coverage/
*.log

# Backups — encrypted dumps live off-box, never in the repo
*.dump.enc
# Raw pg_dump artifacts (restore-drill snapshots) — transient, contain real data, never commit
*.dump
comop-offsite/
